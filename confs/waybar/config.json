[
	{
		"name": "topbar",

		"modules-left": ["niri/workspaces#workspaces", "niri/workspaces#number"],
		"modules-right": ["battery", "clock#local", "clock#utc"],

		"niri/workspaces#workspaces": {
			"format": "{icon}",
			"format-icons": {
				"active": "ο³ë",
				"default": "ο£Σ"
			}
		},

		"niri/workspaces#number": {
			"format": "{value}",
			"current-only": true
		},

		"battery": {
			"states": {
				"good": 95,
				"warning": 30,
				"critical": 20
			},
			"format": "{icon} {capacity}%",
			"format-charging": "ο΅Π {capacity}%",
			"format-plugged": "ο΅Π {capacity}%",
			"format-alt": "{time} {icon}",
			"format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
		},
		"clock#local": {
			"interval": 1,
			"format": "{:%I:%M:%S  %b %d} ",
			"timezone": "US/Central"
		},
		"clock#utc": {
			"interval": 1,
			"format": "({:%H} UTC)",
			"timezone": "Etc/UTC"
		},
		"height": 25,
		"layer": "top",
		"output": ["*"],
		"position": "top"
	}
]
